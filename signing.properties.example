# Copy to signing.properties (gitignored) for release builds.
# Generate once:
#   keytool -genkey -v -keystore trippermate-release.jks -alias trippermate \
#     -keyalg RSA -keysize 2048 -validity 10000 -storepass YOUR_STORE_PASS -keypass YOUR_KEY_PASS \
#     -dname "CN=TripperMate, OU=Community, O=TripperMate, L=India, ST=NA, C=IN"
storeFile=../trippermate-release.jks
storePassword=YOUR_STORE_PASS
keyAlias=trippermate
keyPassword=YOUR_KEY_PASS
