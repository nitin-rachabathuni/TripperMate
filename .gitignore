*.iml
.gradle
/local.properties
/.idea/
.DS_Store
/build
/captures
.externalNativeBuild
.cxx
local.properties

# Firebase is bring-your-own-project — each user drops in their own (the build runs
# fully local without it). Never commit the author's config to a public repo.
google-services.json
app/google-services.json

# Distributable APKs live on GitHub Releases, not in the repo.
/dist/
*.apk
# Per-version release folders (APK + changelog) kept locally, untracked.
/version */

# Device logs / captures — may contain tokens, account data, or RE-app traces. NEVER commit.
*.log
/captures/
* trace

# Release signing — the private key + its credentials. NEVER commit these.
signing.properties
*.jks
*.keystore

# Local dev/test tooling (dash emulator + Firebase push/pull scripts). Kept on the author's
# machine — it references a personal Firebase project and isn't part of the app. NEVER commit
# the Firebase Admin service-account key it uses.
/tools/
serviceAccount.json
node_modules/

# Machine-local Claude Code settings — not for the public repo.
.claude/settings.local.json
*.apk
